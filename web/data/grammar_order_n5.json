[{"id":"76de95b428db","level":"N5","category":"助詞","pattern":"〜の（所屬・修飾）","before":"","frags":["これは","私（わたし）の","傘（かさ）","です。"],"after":"","connection":"名詞 ＋ の ＋ 名詞","note":"後面名詞可省略，如「私のです」。","ex_zh":"這是我的傘。"},{"id":"1091ae5e1972","level":"N5","category":"助詞","pattern":"〜ね","before":"","frags":["今日（きょう）は","いい","天気（てんき）","ですね"],"after":"。","connection":"普通形／丁寧形 ＋ ね","note":"期待對方認同，語氣親切。","ex_zh":"今天天氣真好呢。"},{"id":"7ecdb8ff6e06","level":"N5","category":"助詞","pattern":"〜よ","before":"","frags":["この","店（みせ）のケーキは","おいしい","ですよ"],"after":"。","connection":"普通形／丁寧形 ＋ よ","note":"提供新資訊或提醒，語氣稍強。","ex_zh":"這家店的蛋糕很好吃喔。"},{"id":"3810a07fdd16","level":"N5","category":"助詞","pattern":"〜ぐらい","before":"毎日（まいにち）","frags":["二時間（にじかん）","ぐらい","勉強（べんきょう）","します"],"after":"。","connection":"數量詞 ＋ ぐらい","note":"也寫作くらい，兩者通用。","ex_zh":"每天大約唸兩小時的書。"},{"id":"8d8c17f64c4f","level":"N5","category":"助詞","pattern":"〜だけ","before":"","frags":["日曜日（にちようび）","だけ","休（やす）み","ます"],"after":"。","connection":"名詞／數量詞 ＋ だけ","note":"語氣中性；しか〜ない則帶不足的語感。","ex_zh":"只有星期日休息。"},{"id":"5d1fe3a6897e","level":"N5","category":"助詞","pattern":"〜より（比較）","before":"","frags":["今日（きょう）は","昨日（きのう）","より暑（あつ）い","です"],"after":"。","connection":"名詞 ＋ より","note":"常與ほうが搭配成「〜のほうが〜より」。","ex_zh":"今天比昨天熱。"},{"id":"ce3bf0f0c0e3","level":"N5","category":"助詞","pattern":"〜に（頻率・比例）","before":"","frags":["一週間（いっしゅうかん）に","三回（さんかい）","運動（うんどう）","します"],"after":"。","connection":"時間名詞 ＋ に ＋ 次數","note":"「期間＋に＋次數」的固定用法。","ex_zh":"一週運動三次。"},{"id":"38cb030eb15b","level":"N5","category":"です・ます・指示","pattern":"〜じゃありません","before":"","frags":["私（わたし）は","日本人（にほんじん）","じゃ","ありません"],"after":"。","connection":"名詞／な形容詞 ＋ じゃありません","note":"較正式為「ではありません」。","ex_zh":"我不是日本人。"},{"id":"79e5214a44a5","level":"N5","category":"です・ます・指示","pattern":"〜ます","before":"","frags":["毎朝（まいあさ）","新聞（しんぶん）","を読（よ）み","ます"],"after":"。","connection":"動詞ます形","note":"表習慣或未來的動作。","ex_zh":"每天早上看報紙。"},{"id":"9cd756b1b206","level":"N5","category":"です・ます・指示","pattern":"〜ません","before":"","frags":["私（わたし）は","お酒（さけ）","を飲（の）み","ません"],"after":"。","connection":"動詞ます形（去ます）＋ ません","note":"邀約時「〜ませんか」表委婉勸誘。","ex_zh":"我不喝酒。"},{"id":"063537b5ff30","level":"N5","category":"です・ます・指示","pattern":"〜ました","before":"","frags":["昨日（きのう）","映画（えいが）","を見（み）","ました"],"after":"。","connection":"動詞ます形（去ます）＋ ました","note":"表已完成的動作。","ex_zh":"昨天看了電影。"},{"id":"52d822e672a3","level":"N5","category":"です・ます・指示","pattern":"〜ませんでした","before":"","frags":["先週（せんしゅう）は","どこへも","行（い）き","ませんでした"],"after":"。","connection":"動詞ます形（去ます）＋ ませんでした","note":"ました的否定過去。","ex_zh":"上週哪裡都沒去。"},{"id":"e539fafd37a7","level":"N5","category":"です・ます・指示","pattern":"この／その／あの","before":"","frags":["この本（ほん）は","とても","面白（おもしろ）い","です"],"after":"。","connection":"この／その／あの ＋ 名詞","note":"必須接名詞，不能單獨使用。","ex_zh":"這本書非常有趣。"},{"id":"aae662869b02","level":"N5","category":"形容詞","pattern":"い形〜いです","before":"","frags":["この","料理（りょうり）は","辛（から）い","です"],"after":"。","connection":"い形容詞（辭書形）＋ です","note":"い形容詞直接加です，不加だ。","ex_zh":"這道菜很辣。"},{"id":"fb5d5075fa8b","level":"N5","category":"形容詞","pattern":"い形〜くないです","before":"","frags":["この","部屋（へや）は","広（ひろ）くない","です"],"after":"。","connection":"い形容詞（去い）＋ くないです","note":"也可說「〜くありません」。いい→よくない。","ex_zh":"這房間不寬敞。"},{"id":"7645495b7a2b","level":"N5","category":"形容詞","pattern":"い形〜かったです","before":"","frags":["旅行（りょこう）は","とても","楽（たの）しかった","です"],"after":"。","connection":"い形容詞（去い）＋ かったです","note":"不可說「〜いでした」。いい→よかった。","ex_zh":"旅行非常愉快。"},{"id":"70aa6e0184c6","level":"N5","category":"形容詞","pattern":"い形〜くなかったです","before":"","frags":["映画（えいが）は","あまり","面白（おもしろ）くなかった","です"],"after":"。","connection":"い形容詞（去い）＋ くなかったです","note":"也可說「〜くありませんでした」。","ex_zh":"電影不太有趣。"},{"id":"2795ecc4e5bb","level":"N5","category":"形容詞","pattern":"な形〜です","before":"","frags":["この","町（まち）は","静（しず）か","です"],"after":"。","connection":"な形容詞（語幹）＋ です","note":"修飾名詞時要加な，如「静かな町」。","ex_zh":"這個城鎮很安靜。"},{"id":"d4abc2ab4320","level":"N5","category":"形容詞","pattern":"な形〜じゃないです","before":"","frags":["この","駅（えき）は","便利（べんり）じゃない","です"],"after":"。","connection":"な形容詞（語幹）＋ じゃないです","note":"也可說「〜ではありません」。","ex_zh":"這個車站不方便。"},{"id":"0283ed235104","level":"N5","category":"形容詞","pattern":"〜くて／〜で（並列）","before":"","frags":["この","店（みせ）は","安（やす）くて","おいしいです"],"after":"。","connection":"い形（去い）＋ くて／な形（語幹）＋ で","note":"い形用くて，な形與名詞用で。","ex_zh":"這家店又便宜又好吃。"},{"id":"be01ea08fde0","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜ないでください","before":"","frags":["ここで写真（しゃしん）を","撮（と）ら","ないで","ください"],"after":"。","connection":"動詞ない形 ＋ でください","note":"て形肯定請求的否定版本。","ex_zh":"請不要在這裡拍照。"},{"id":"c57887d21108","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜てから","before":"","frags":["宿題（しゅくだい）を","してから、","テレビを","見（み）ます"],"after":"。","connection":"動詞て形 ＋ から","note":"強調前項完成後才進行後項。","ex_zh":"做完功課後再看電視。"},{"id":"09b593df4ac8","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜ませんか","before":"","frags":["週末（しゅうまつ）、映画（えいが）を","見（み）に","行（い）き","ませんか"],"after":"。","connection":"動詞ます形（去ます）＋ ませんか","note":"比ましょう更尊重對方意願。","ex_zh":"週末要不要去看電影？"},{"id":"faa9a26d987e","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜たいです","before":"","frags":["冷（つめ）たい","水（みず）が","飲（の）み","たいです"],"after":"。","connection":"動詞ます形（去ます）＋ たいです","note":"受詞助詞を可換成が；只用於第一人稱。","ex_zh":"想喝冰水。"},{"id":"aadd14075fdd","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜ながら","before":"","frags":["音楽（おんがく）を","聞（き）きながら","勉強（べんきょう）","します"],"after":"。","connection":"動詞ます形（去ます）＋ ながら","note":"主要動作放在後半句。","ex_zh":"一邊聽音樂一邊唸書。"},{"id":"b3ee69c7a45d","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜たことがあります","before":"","frags":["日本（にほん）へ","行（い）った","ことが","あります"],"after":"。","connection":"動詞た形 ＋ ことがあります","note":"否定為「〜たことがありません」。","ex_zh":"曾經去過日本。"},{"id":"5ebbb7fe324b","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜まえに","before":"","frags":["寝（ね）る","前（まえ）に","歯（は）を磨（みが）き","ます"],"after":"。","connection":"動詞辞書形／名詞 ＋ の ＋ まえに","note":"動詞用辭書形；名詞需加の。","ex_zh":"睡覺前刷牙。"},{"id":"25d855a417ef","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜あとで","before":"","frags":["ごはんを","食（た）べた後（あと）で、","薬（くすり）を","飲（の）みます"],"after":"。","connection":"動詞た形／名詞 ＋ の ＋ あとで","note":"動詞用た形；名詞需加の。","ex_zh":"吃完飯後吃藥。"},{"id":"577900e42a64","level":"N5","category":"動詞活用・依頼許可禁止","pattern":"〜たほうがいいです","before":"","frags":["早（はや）く","寝（ね）た","ほうが","いいですよ"],"after":"。","connection":"動詞た形 ＋ ほうがいいです","note":"否定建議用「〜ないほうがいいです」。","ex_zh":"早點睡比較好喔。"},{"id":"3449e72555aa","level":"N5","category":"接続・理由・その他","pattern":"〜から（原因・理由）","before":"","frags":["時間（じかん）が","ない","から、","急（いそ）ぎましょう"],"after":"。","connection":"普通形／丁寧形 ＋ から","note":"から重主觀理由；ので較客觀委婉。","ex_zh":"因為沒時間，快一點吧。"},{"id":"1932b1ac4762","level":"N5","category":"接続・理由・その他","pattern":"〜が（逆接）","before":"","frags":["この店（みせ）は高（たか）い","ですが、","おいしい","です"],"after":"。","connection":"普通形／丁寧形 ＋ が","note":"書面較常用；口語多用けど。","ex_zh":"這家店雖然貴，但很好吃。"},{"id":"c05db77b777b","level":"N5","category":"接続・理由・その他","pattern":"そして","before":"昨日（きのう）は","frags":["買（か）い物（もの）を","しました。","そして、","映画（えいが）を見（み）ました"],"after":"。","connection":"句子。＋ そして ＋ 句子。","note":"用於句首連接兩個句子。","ex_zh":"昨天去購物了。然後看了電影。"},{"id":"74c0f2b67846","level":"N5","category":"接続・理由・その他","pattern":"それから","before":"","frags":["宿題（しゅくだい）を","します。","それから、","寝（ね）ます"],"after":"。","connection":"句子。＋ それから ＋ 句子。","note":"也可用來補充追加項目。","ex_zh":"先寫功課。然後睡覺。"},{"id":"1109f769f833","level":"N5","category":"接続・理由・その他","pattern":"でも","before":"この服（ふく）は","frags":["かわいいです","。でも、","高（たか）い","です。"],"after":"","connection":"句子。＋ でも ＋ 句子。","note":"置於句首，口語常用。","ex_zh":"這件衣服很可愛。不過很貴。"},{"id":"64aaaeb09e98","level":"N5","category":"接続・理由・その他","pattern":"〜でしょう","before":"","frags":["明日（あした）は","雨（あめ）が","降（ふ）る","でしょう"],"after":"。","connection":"普通形（名詞・な形去だ）＋ でしょう","note":"語調上揚時可表徵求同意。","ex_zh":"明天大概會下雨吧。"},{"id":"41b7155f0bf2","level":"N5","category":"接続・理由・その他","pattern":"〜つもりです","before":"","frags":["夏休（なつやす）みに国（くに）へ","帰（かえ）る","つもり","です"],"after":"。","connection":"動詞辞書形／ない形 ＋ つもりです","note":"否定打算用「〜ないつもりです」。","ex_zh":"暑假打算回國。"},{"id":"c10a23b635d7","level":"N5","category":"接続・理由・その他","pattern":"〜がほしいです","before":"","frags":["新（あたら）しい","かばんが","ほしい","です"],"after":"。","connection":"名詞 ＋ がほしいです","note":"對象用が；只用於第一人稱的願望。","ex_zh":"想要新的包包。"},{"id":"5549100c3d11","level":"N5","category":"接続・理由・その他","pattern":"〜のが好きです","before":"","frags":["私（わたし）は","本（ほん）を","読（よ）むのが","好（す）きです"],"after":"。","connection":"動詞辞書形 ＋ のが好きです","note":"の把動詞名詞化；對象用が。","ex_zh":"我喜歡看書。"},{"id":"b4d60532cbd7","level":"N5","category":"接続・理由・その他","pattern":"〜のが上手です／下手です","before":"","frags":["姉（あね）は","料理（りょうり）を","作（つく）るのが","上手（じょうず）です"],"after":"。","connection":"動詞辞書形 ＋ のが上手です／下手です","note":"名詞直接用「名詞が上手です」。","ex_zh":"姊姊很擅長做菜。"},{"id":"ab9e52de606f","level":"N5","category":"接続・理由・その他","pattern":"〜という","before":"","frags":["「すし」","という","料理（りょうり）を","食（た）べました"],"after":"。","connection":"名詞 ＋ という ＋ 名詞","note":"用於說明對方可能不知道的名稱。","ex_zh":"吃了叫做「壽司」的料理。"},{"id":"a4e467fec14a","level":"N5","category":"接続・理由・その他","pattern":"まだ〜ていません","before":"","frags":["宿題（しゅくだい）","はまだ","終（お）わって","いません"],"after":"。","connection":"まだ ＋ 動詞て形 ＋ いません","note":"不說「まだ〜ませんでした」。","ex_zh":"作業還沒做完。"},{"id":"9791bbf0c14d","level":"N5","category":"接続・理由・その他","pattern":"まだ〜ています","before":"","frags":["父（ちち）","はまだ","働（はたら）いて","います"],"after":"。","connection":"まだ ＋ 動詞て形 ＋ います","note":"まだ也可接肯定，如「まだ雨（あめ）です」。","ex_zh":"父親還在工作。"},{"id":"5dbb2e06a4d6","level":"N5","category":"接続・理由・その他","pattern":"〜ずつ","before":"一人（ひとり）に","frags":["二枚（にまい）","ずつ","配（くば）り","ます"],"after":"。","connection":"數量詞 ＋ ずつ","note":"常表平均分配或逐次進行。","ex_zh":"每人各發兩張。"},{"id":"83d0c01c1501","level":"N5","category":"接続・理由・その他","pattern":"〜でも（例示・提議）","before":"","frags":["お茶（ちゃ）","でも","飲（の）み","ませんか"],"after":"。","connection":"名詞 ＋ でも","note":"委婉舉例，不限定於該項。","ex_zh":"要不要喝點茶之類的？"},{"id":"6d0f07a857ff","level":"N5","category":"接続・理由・その他","pattern":"〜ね／〜よね（確認）","before":"","frags":["明日（あした）の会議（かいぎ）は","十時（じゅうじ）から","です","よね"],"after":"。","connection":"普通形／丁寧形 ＋ よね","note":"よね用於自己記得但想再確認時。","ex_zh":"明天的會議是十點開始對吧？"},{"id":"3e5dcdbbe337","level":"N5","category":"接続・理由・その他","pattern":"〜たいと思います","before":"将来（しょうらい）、","frags":["日本（にほん）で","働（はたら）き","たい","と思（おも）います"],"after":"。","connection":"動詞ます形（去ます）＋ たいと思います","note":"比たいです更客氣、委婉。","ex_zh":"將來想在日本工作。"},{"id":"f0cf39a485f8","level":"N5","category":"接続・理由・その他","pattern":"〜が、〜（前置き）","before":"","frags":["すみませんが、","道（みち）を","教（おし）えて","ください"],"after":"。","connection":"丁寧形 ＋ が、","note":"此處が非逆接，只是禮貌的鋪陳。","ex_zh":"不好意思，請告訴我路怎麼走。"}]