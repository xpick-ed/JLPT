[{"id":"de342fddf39a","level":"N4","category":"可能形・自発","pattern":"〜られる／〜える（可能形）","before":"","frags":["私（わたし）は","漢字（かんじ）が","読（よ）め","ます。"],"after":"","connection":"動詞可能形","note":"五段動詞語尾改e段＋る；一段動詞去る＋られる","ex_zh":"我會讀漢字。"},{"id":"3f606fd41775","level":"N4","category":"可能形・自発","pattern":"〜ことができる","before":"","frags":["日本語（にほんご）を","話（はな）す","ことが","できます。"],"after":"","connection":"動詞辞書形 ＋ ことができる","note":"＝動詞可能形，語感較正式","ex_zh":"我會說日語。"},{"id":"1711e590322e","level":"N4","category":"可能形・自発","pattern":"〜が聞こえる","before":"","frags":["鳥（とり）の","声（こえ）が","聞（き）こえ","ます。"],"after":"","connection":"名詞 ＋ が聞こえる","note":"非刻意去聽，與聞ける不同","ex_zh":"聽得見鳥叫聲。"},{"id":"1ebf357a9922","level":"N4","category":"可能形・自発","pattern":"〜やすい","before":"","frags":["この","本（ほん）は","分（わ）かり","やすいです。"],"after":"","connection":"動詞ます形 ＋ やすい","note":"い形容詞變化；反義為〜にくい","ex_zh":"這本書很好懂。"},{"id":"8f3e93585f96","level":"N4","category":"可能形・自発","pattern":"〜にくい","before":"","frags":["この","薬（くすり）は","飲（の）み","にくいです。"],"after":"","connection":"動詞ます形 ＋ にくい","note":"い形容詞變化；反義為〜やすい","ex_zh":"這個藥很難吞。"},{"id":"a8b4f4eb56b2","level":"N4","category":"可能形・自発","pattern":"〜方","before":"","frags":["漢字（かんじ）の","書（か）き方（かた）を","教（おし）えて","ください。"],"after":"","connection":"動詞ます形 ＋ 方","note":"名詞化，表方法","ex_zh":"請教我漢字的寫法。"},{"id":"34b6e65cb323","level":"N4","category":"可能形・自発","pattern":"〜ようになる（能力の変化）","before":"","frags":["毎日（まいにち）練習（れんしゅう）して、","泳（およ）げる","ように","なりました。"],"after":"","connection":"動詞可能形 ＋ ようになる","note":"強調從不會到會的能力變化","ex_zh":"每天練習後，變得會游泳了。"},{"id":"4821efd497f2","level":"N4","category":"可能形・自発","pattern":"〜なくなる","before":"最近（さいきん）、","frags":["朝（あさ）ご飯（はん）を","食（た）べ","なく","なりました。"],"after":"","connection":"動詞ない形（去い）＋ くなる","note":"〜ようになる的否定變化","ex_zh":"最近變得不吃早餐了。"},{"id":"b5ef257506e6","level":"N4","category":"可能形・自発","pattern":"〜こと（名詞化）","before":"私（わたし）の趣味（しゅみ）は","frags":["歌（うた）を","歌（うた）う","こと","です。"],"after":"","connection":"動詞辞書形／普通形 ＋ こと","note":"與〜のが／〜のは用法相近","ex_zh":"我的興趣是唱歌。"},{"id":"1a10c16a0970","level":"N4","category":"受身・使役・使役受身","pattern":"〜は〜に〜を〜られる（持ち主の受身）","before":"","frags":["私（わたし）は弟（おとうと）にケーキを","食（た）べ","られ","ました。"],"after":"","connection":"名詞は ＋ 名詞に ＋ 名詞を ＋ 動詞受身形","note":"主語是受影響的所有者，非物品本身","ex_zh":"我的蛋糕被弟弟吃掉了。"},{"id":"b1436e2d10df","level":"N4","category":"受身・使役・使役受身","pattern":"〜てある","before":"","frags":["壁（かべ）に地図（ちず）が","貼（は）って","あり","ます。"],"after":"","connection":"動詞て形 ＋ ある","note":"他動詞＋てある，強調人為結果狀態","ex_zh":"牆上貼著地圖。"},{"id":"215653d14715","level":"N4","category":"受身・使役・使役受身","pattern":"〜させる（使役形）","before":"","frags":["母（はは）は妹（いもうと）に部屋（へや）を","掃除（そうじ）","させ","ました。"],"after":"","connection":"動詞使役形","note":"五段語尾改a段＋せる；一段去る＋させる","ex_zh":"媽媽叫妹妹打掃房間。"},{"id":"2ebb9d4e3cb1","level":"N4","category":"受身・使役・使役受身","pattern":"〜てほしい","before":"","frags":["手伝（てつだ）って","ほしい","ことが","あります"],"after":"。","connection":"動詞て形 ＋ ほしい","note":"對象用「に」；否定為〜ないでほしい","ex_zh":"有件事想請你幫忙。"},{"id":"a3d04256faf8","level":"N4","category":"条件形","pattern":"〜ば","before":"","frags":["薬（くすり）を","飲（の）めば、","元気（げんき）に","なります"],"after":"。","connection":"動詞ば形／い形容詞ければ／な形容詞なら","note":"重前後因果關係，後句多不接意志","ex_zh":"吃了藥的話就會好起來。"},{"id":"537f97d7648d","level":"N4","category":"条件形","pattern":"〜なら","before":"","frags":["日本（にほん）へ","行（い）くなら、","京都（きょうと）が","いいですよ"],"after":"。","connection":"名詞／普通形 ＋ なら","note":"承接對方所提話題給建議","ex_zh":"如果要去日本的話，京都不錯喔。"},{"id":"f7ddd9d6504a","level":"N4","category":"条件形","pattern":"〜たら","before":"駅（えき）に","frags":["着（つ）いたら、","電話（でんわ）","して","ください"],"after":"。","connection":"動詞た形 ＋ ら（普通形過去 ＋ ら）","note":"口語最常用，適用範圍最廣","ex_zh":"到車站後請打電話給我。"},{"id":"034a583238ef","level":"N4","category":"条件形","pattern":"〜と（自然な結果）","before":"春（はる）に","frags":["なると、","桜（さくら）が","咲（さ）き","ます"],"after":"。","connection":"動詞辞書形／ない形 ＋ と","note":"後句不接意志、命令、請求","ex_zh":"一到春天，櫻花就會開。"},{"id":"3def0175649c","level":"N4","category":"条件形","pattern":"〜と（道案内・操作）","before":"この道（みち）をまっすぐ","frags":["行（い）くと、","銀行（ぎんこう）が","あり","ます"],"after":"。","connection":"動詞辞書形 ＋ と","note":"指路、機械操作常用","ex_zh":"沿這條路直走，就會有銀行。"},{"id":"8efbab3a01a6","level":"N4","category":"条件形","pattern":"〜ばよかった","before":"","frags":["もっと早（はや）く","出（で）れば","よかった","です"],"after":"。","connection":"動詞ば形 ＋ よかった","note":"表未做而後悔；否定為〜なければよかった","ex_zh":"要是早點出門就好了。"},{"id":"57ccafd2029c","level":"N4","category":"条件形","pattern":"〜たらどうですか","before":"","frags":["医者（いしゃ）に","行（い）ったら","どう","ですか"],"after":"。","connection":"動詞た形 ＋ らどうですか","note":"委婉建議；口語可說〜たら？","ex_zh":"去看醫生怎麼樣？"},{"id":"a78083ea3c9e","level":"N4","category":"条件形","pattern":"〜ても","before":"","frags":["雨（あめ）が","降（ふ）っても、","試合（しあい）を","します"],"after":"。","connection":"動詞て形 ＋ も（い形容詞くても／な形容詞でも）","note":"逆接假設","ex_zh":"即使下雨也要比賽。"},{"id":"1930fd86895f","level":"N4","category":"条件形","pattern":"〜なくても","before":"","frags":["急（いそ）が","なくても、","間（ま）に","合（あ）います"],"after":"。","connection":"動詞ない形（去い）＋ くても","note":"〜ても的否定形","ex_zh":"就算不趕也來得及。"},{"id":"264076f4ded8","level":"N4","category":"条件形","pattern":"もし〜たら","before":"もし","frags":["雨（あめ）が","降（ふ）ったら、","行（い）き","ません"],"after":"。","connection":"もし ＋ 動詞た形 ＋ ら","note":"「もし」加強假設語氣","ex_zh":"如果下雨的話就不去。"},{"id":"b784c08b4913","level":"N4","category":"条件形","pattern":"〜たら〜た（発見）","before":"","frags":["窓（まど）を","開（あ）けたら、","雪（ゆき）が","降（ふ）っていました"],"after":"。","connection":"動詞た形 ＋ ら ＋ 動詞た形","note":"後句為說話者當場的新發現","ex_zh":"打開窗戶一看，發現正在下雪。"},{"id":"915b59e7395e","level":"N4","category":"条件形","pattern":"〜たら（依頼・希望の前提）","before":"","frags":["時間（じかん）が","あったら、","遊（あそ）びに","来（き）てください"],"after":"。","connection":"動詞た形 ＋ ら","note":"後句可接請求、意志（與〜と不同）","ex_zh":"有時間的話請來玩。"},{"id":"df42e988ccab","level":"N4","category":"条件形","pattern":"〜ば〜ほど","before":"","frags":["考（かんが）えれば","考（かんが）えるほど、","分（わ）から","なくなります"],"after":"。","connection":"動詞ば形 ＋ 動詞辞書形 ＋ ほど","note":"程度隨之遞增","ex_zh":"越想越搞不懂。"},{"id":"2c4b3345b1a6","level":"N4","category":"条件形","pattern":"〜ないと（いけない）","before":"もう","frags":["行（い）か","ないと、","遅（おく）れ","ます"],"after":"。","connection":"動詞ない形 ＋ と（いけない）","note":"口語常省略後半，等同〜なければならない","ex_zh":"再不走就要遲到了。"},{"id":"2c4d4247d8e6","level":"N4","category":"意志・推量・意向","pattern":"〜（よ）うとする","before":"","frags":["出（で）かけようと","したとき、","電話（でんわ）が","鳴（な）りました"],"after":"。","connection":"動詞意向形 ＋ とする","note":"表動作即將發生或努力嘗試","ex_zh":"正想出門時，電話響了。"},{"id":"6f4f980236f9","level":"N4","category":"意志・推量・意向","pattern":"〜つもり","before":"","frags":["夏休（なつやす）みに国（くに）へ","帰（かえ）る","つもり","です"],"after":"。","connection":"動詞辞書形／ない形 ＋ つもり","note":"表個人事前的打算","ex_zh":"暑假打算回國。"},{"id":"ec8e23c3fc9f","level":"N4","category":"意志・推量・意向","pattern":"〜つもりはない","before":"","frags":["今（いま）の","会社（かいしゃ）を","やめる","つもりはありません"],"after":"。","connection":"動詞辞書形 ＋ つもりはない","note":"比〜ないつもり語氣更強的否定","ex_zh":"我沒有要辭掉現在的公司。"},{"id":"bd2645207746","level":"N4","category":"意志・推量・意向","pattern":"〜予定","before":"来週（らいしゅう）、","frags":["大阪（おおさか）へ","出張（しゅっちょう）する","予定（よてい）","です"],"after":"。","connection":"動詞辞書形／名詞の ＋ 予定","note":"比〜つもり客觀，多指已排定的計畫","ex_zh":"下週預定去大阪出差。"},{"id":"1893ed08bd70","level":"N4","category":"意志・推量・意向","pattern":"〜はず","before":"","frags":["彼（かれ）はもう","着（つ）いて","いる","はずです"],"after":"。","connection":"動詞・い形容詞普通形／な形容詞な／名詞の ＋ はず","note":"依據理由推論；否定為〜ないはず／〜はずがない","ex_zh":"他應該已經到了。"},{"id":"695b3e3217f2","level":"N4","category":"意志・推量・意向","pattern":"〜と思う","before":"","frags":["この","映画（えいが）は","面白（おもしろ）いと","思（おも）います"],"after":"。","connection":"普通形 ＋ と思う","note":"表個人意見或判斷","ex_zh":"我覺得這部電影很有趣。"},{"id":"fa3a38a62879","level":"N4","category":"意志・推量・意向","pattern":"〜（よ）うと思う","before":"","frags":["今度（こんど）の休（やす）みに、","山（やま）に","登（のぼ）ろう","と思（おも）います"],"after":"。","connection":"動詞意向形 ＋ と思う","note":"當場決定或最近的打算","ex_zh":"這次假期我打算去爬山。"},{"id":"6e1a7c540f4b","level":"N4","category":"意志・推量・意向","pattern":"〜ことにする","before":"","frags":["毎朝（まいあさ）、","走（はし）る","ことに","しました"],"after":"。","connection":"動詞辞書形／ない形 ＋ ことにする","note":"主觀決定；持續的習慣用〜ことにしている","ex_zh":"我決定每天早上跑步。"},{"id":"e8e775abe3f2","level":"N4","category":"意志・推量・意向","pattern":"〜ことになる","before":"","frags":["来月（らいげつ）、","東京（とうきょう）へ","転勤（てんきん）する","ことになりました"],"after":"。","connection":"動詞辞書形／ない形 ＋ ことになる","note":"非自己決定，多為外部安排的結果","ex_zh":"下個月要調職到東京了。"},{"id":"86677804f0f2","level":"N4","category":"変化・目的","pattern":"〜ていく","before":"","frags":["これから、","寒（さむ）く","なって","いきます"],"after":"。","connection":"動詞て形 ＋ いく","note":"時間上朝未來變化；空間上遠離","ex_zh":"接下來會漸漸變冷。"},{"id":"c8b80bfbb890","level":"N4","category":"変化・目的","pattern":"〜てくる","before":"","frags":["だんだん","暖（あたた）かく","なって","きました"],"after":"。","connection":"動詞て形 ＋ くる","note":"從過去到現在的變化；空間上靠近","ex_zh":"漸漸變暖和了。"},{"id":"691741742736","level":"N4","category":"変化・目的","pattern":"〜ために（目的）","before":"","frags":["車（くるま）を","買（か）うために、","お金（かね）を","貯（た）めています"],"after":"。","connection":"動詞辞書形／名詞の ＋ ために","note":"前接意志動詞；前後主語需一致","ex_zh":"為了買車正在存錢。"},{"id":"ebabdcae22eb","level":"N4","category":"変化・目的","pattern":"〜のに（目的・用途）","before":"","frags":["この道具（どうぐ）は","野菜（やさい）を","切（き）るのに","使（つか）います"],"after":"。","connection":"動詞辞書形 ＋ のに","note":"表用途；與逆接的〜のに不同","ex_zh":"這個工具是用來切菜的。"},{"id":"bab544814916","level":"N4","category":"変化・目的","pattern":"〜ように言う","before":"","frags":["先生（せんせい）は","静（しず）かに","する","ように言（い）いました"],"after":"。","connection":"動詞辞書形／ない形 ＋ ように言う","note":"間接引述指示、請求、勸告","ex_zh":"老師叫大家安靜。"},{"id":"5a17240a6375","level":"N4","category":"変化・目的","pattern":"〜ようにする","before":"","frags":["毎日（まいにち）野菜（やさい）を","食（た）べる","ように","しています"],"after":"。","connection":"動詞辞書形／ない形 ＋ ようにする","note":"持續努力用〜ようにしている","ex_zh":"我盡量每天吃蔬菜。"},{"id":"6d3f66fb1661","level":"N4","category":"変化・目的","pattern":"〜ようになる（習慣の変化）","before":"","frags":["毎朝（まいあさ）、","早（はや）く","起（お）きる","ようになりました"],"after":"。","connection":"動詞辞書形／ない形 ＋ ようになる","note":"強調習慣或狀態的變化過程","ex_zh":"變得每天早起了。"},{"id":"d700ef1f085f","level":"N4","category":"変化・目的","pattern":"〜ところだ","before":"","frags":["今（いま）から","出（で）かける","ところ","です。"],"after":"","connection":"動詞辞書形 ＋ ところだ","note":"動作即將開始","ex_zh":"現在正要出門。"},{"id":"93ae7bbbe954","level":"N4","category":"変化・目的","pattern":"〜ているところだ","before":"今（いま）、","frags":["宿題（しゅくだい）を","している","ところ","です。"],"after":"","connection":"動詞ている ＋ ところだ","note":"強調正處於進行的當下","ex_zh":"現在正在做作業。"},{"id":"002271a9cd5a","level":"N4","category":"変化・目的","pattern":"〜たところだ","before":"たった今（いま）、","frags":["家（いえ）に","帰（かえ）った","ところ","です。"],"after":"","connection":"動詞た形 ＋ ところだ","note":"與〜たばかり相近，強調時間點","ex_zh":"我剛回到家。"},{"id":"bdeefe71f5d5","level":"N4","category":"変化・目的","pattern":"〜たばかり","before":"","frags":["この会社（かいしゃ）に","入（はい）った","ばかり","です。"],"after":"","connection":"動詞た形 ＋ ばかり","note":"主觀感覺時間短，未必客觀剛結束","ex_zh":"我才剛進這家公司。"},{"id":"1163cb1691d1","level":"N4","category":"変化・目的","pattern":"〜てしまう","before":"","frags":["大切（たいせつ）な","傘（かさ）を","なくして","しまいました。"],"after":"","connection":"動詞て形 ＋ しまう","note":"表完成或懊悔；口語縮約為〜ちゃう","ex_zh":"把重要的傘弄丟了。"},{"id":"96ff16924ac8","level":"N4","category":"変化・目的","pattern":"〜ばかり","before":"","frags":["弟（おとうと）は","ゲーム","ばかり","しています。"],"after":"","connection":"名詞／動詞て形 ＋ ばかり","note":"表反覆、偏重同一事物","ex_zh":"弟弟老是在打電動。"},{"id":"71cdd1f1e0c9","level":"N4","category":"様態・伝聞・推定","pattern":"〜そうだ（様態）","before":"","frags":["雨（あめ）が","降（ふ）り","そう","です。"],"after":"","connection":"動詞ます形／い形容詞（去い）／な形容詞 ＋ そうだ","note":"伝聞的「〜そうだ」接普通形，意思是「聽說」，兩者不同","ex_zh":"看起來好像要下雨了。"},{"id":"193598145752","level":"N4","category":"様態・伝聞・推定","pattern":"〜そうだ（伝聞）","before":"天気予報（てんきよほう）によると、","frags":["明日（あした）は雪（ゆき）が","降（ふ）る","そう","だ。"],"after":"","connection":"普通形 ＋ そうだ","note":"常與「〜によると」搭配表示消息來源","ex_zh":"根據天氣預報，聽說明天會下雪。"},{"id":"235843108733","level":"N4","category":"様態・伝聞・推定","pattern":"〜ようだ","before":"彼（かれ）は","frags":["もう","帰（かえ）った","よう","だ。"],"after":"","connection":"名詞の／な形容詞な／い形容詞・動詞普通形 ＋ ようだ","note":"較「〜そうだ」更客觀，書面感較強","ex_zh":"他好像已經回去了。"},{"id":"bdc38d6e5f64","level":"N4","category":"様態・伝聞・推定","pattern":"〜みたいだ","before":"","frags":["誰（だれ）か","来（き）た","みたい","だ。"],"after":"","connection":"名詞／な形容詞／い形容詞・動詞普通形 ＋ みたいだ","note":"「〜みたいだ」是「〜ようだ」的口語形，也可表比喻","ex_zh":"好像有誰來了。"},{"id":"83d2560ea593","level":"N4","category":"様態・伝聞・推定","pattern":"〜らしい","before":"","frags":["田中（たなか）さんは","風邪（かぜ）を","ひいた","らしい。"],"after":"","connection":"名詞／な形容詞／い形容詞・動詞普通形 ＋ らしい","note":"根據聽來或看到的資訊推測，客觀性較高","ex_zh":"田中先生好像感冒了。"},{"id":"39fe9c21ac3e","level":"N4","category":"様態・伝聞・推定","pattern":"〜ように見える","before":"","frags":["彼女（かのじょ）は","元気（げんき）な","ように","見（み）える。"],"after":"","connection":"名詞の／な形容詞な／い形容詞・動詞普通形 ＋ ように見える","note":"強調「以視覺判斷」的樣子","ex_zh":"她看起來很有精神。"},{"id":"25f032dc0237","level":"N4","category":"様態・伝聞・推定","pattern":"〜っぽい","before":"","frags":["この牛乳（ぎゅうにゅう）は","水（みず）っぽい","味（あじ）が","する。"],"after":"","connection":"名詞／動詞ます形／い形容詞（去い）＋ っぽい","note":"口語，常含負面或「像…卻不完全是」的語感","ex_zh":"這牛奶有股水水的味道。"},{"id":"5bdee85c12ab","level":"N4","category":"様態・伝聞・推定","pattern":"〜らしい（典型）","before":"","frags":["今日（きょう）は","春（はる）らしい暖（あたた）かい","日（ひ）","だ。"],"after":"","connection":"名詞 ＋ らしい","note":"此為「典型・符合本質」的用法，非推測用法","ex_zh":"今天是很有春天氣息的溫暖日子。"},{"id":"ffdb7cbbeefb","level":"N4","category":"様態・伝聞・推定","pattern":"〜そうにない","before":"","frags":["この仕事（しごと）は","今日中（きょうじゅう）に終（お）わり","そうに","ない"],"after":"。","connection":"動詞ます形 ＋ そうにない","note":"「〜そうだ（様態）」的否定，語氣較強","ex_zh":"這工作看起來今天之內做不完。"},{"id":"784a9165bee5","level":"N4","category":"様態・伝聞・推定","pattern":"〜げ","before":"","frags":["子供（こども）が","寂（さび）しげな","顔（かお）を","している"],"after":"。","connection":"い形容詞（去い）／な形容詞語幹 ＋ げ","note":"多接情感形容詞，如寂しい・楽しい・不安","ex_zh":"孩子露出一副寂寞的表情。"},{"id":"faeccc70bf32","level":"N4","category":"様態・伝聞・推定","pattern":"〜がる","before":"","frags":["弟（おとうと）は","暗（くら）い","所（ところ）を","怖（こわ）がる"],"after":"。","connection":"い形容詞（去い）／な形容詞語幹 ＋ がる","note":"描述他人情感、感覺，第一人稱不用","ex_zh":"弟弟很怕黑暗的地方。"},{"id":"f06b1599a2ee","level":"N4","category":"様態・伝聞・推定","pattern":"〜たがる","before":"","frags":["子供（こども）はいつも","お菓子（かし）を","食（た）べ","たがる"],"after":"。","connection":"動詞ます形 ＋ たがる","note":"「〜たい」的第三人稱形式，表他人願望","ex_zh":"小孩總是想吃零食。"},{"id":"3d6cb7a06a30","level":"N4","category":"様態・伝聞・推定","pattern":"〜たがっている","before":"","frags":["彼（かれ）は","新（あたら）しい","車（くるま）を","買（か）いたがっている"],"after":"。","connection":"動詞ます形 ＋ たがっている","note":"強調當下持續的願望狀態，比「たがる」更具體","ex_zh":"他一直想買新車。"},{"id":"3632a4dc9613","level":"N4","category":"様態・伝聞・推定","pattern":"〜って（口語伝聞）","before":"","frags":["田中（たなか）さん、","来週（らいしゅう）","引（ひ）っ越（こ）す","んだって"],"after":"。","connection":"普通形 ＋ って","note":"口語轉述，等同書面的「〜そうだ（伝聞）」","ex_zh":"聽說田中先生下週要搬家。"},{"id":"ccc61bdab99a","level":"N4","category":"授受（てあげる系）","pattern":"〜てさしあげる","before":"","frags":["お客様（きゃくさま）に道（みち）を","教（おし）えて","さしあげ","た"],"after":"。","connection":"動詞て形 ＋ さしあげる","note":"「〜てあげる」的謙讓形，但對上位者用需留意可能顯得高姿態","ex_zh":"我為客人指了路。"},{"id":"df77515716ac","level":"N4","category":"授受（てあげる系）","pattern":"〜てくださる","before":"","frags":["先生（せんせい）が","推薦状（すいせんじょう）を","書（か）いて","くださった"],"after":"。","connection":"動詞て形 ＋ くださる","note":"「〜てくれる」的尊敬形，主語是上位者","ex_zh":"老師為我寫了推薦信。"},{"id":"43f7f4cbbb46","level":"N4","category":"授受（てあげる系）","pattern":"〜てやる","before":"","frags":["毎朝（まいあさ）犬（いぬ）を散歩（さんぽ）に","連（つ）れて","行（い）って","やる"],"after":"。","connection":"動詞て形 ＋ やる","note":"對象為晚輩、寵物、植物，口語有時帶強烈語氣","ex_zh":"我每天早上帶狗去散步。"},{"id":"75c75300b752","level":"N4","category":"授受（てあげる系）","pattern":"お〜する（謙譲）","before":"","frags":["お荷物（にもつ）を","お持（も）ち","し","ます"],"after":"。","connection":"お ＋ 動詞ます形 ＋ する","note":"謙讓語基本句型，降低自己以抬高對方","ex_zh":"我來幫您拿行李。"},{"id":"7f2ad90ad2c4","level":"N4","category":"授受（てあげる系）","pattern":"〜てくれない？","before":"","frags":["ちょっと","手伝（てつだ）って","くれ","ない"],"after":"？","connection":"動詞て形 ＋ くれない？","note":"對親近者的口語請求，比「〜てください」隨意","ex_zh":"可以幫我一下嗎？"},{"id":"94fb829303ef","level":"N4","category":"授受（てあげる系）","pattern":"〜てもらえませんか","before":"","frags":["この漢字（かんじ）の","読（よ）み方（かた）を","教（おし）えて","もらえませんか"],"after":"。","connection":"動詞て形 ＋ もらえませんか","note":"禮貌請求，更客氣可用「〜ていただけませんか」","ex_zh":"能否請您教我這個漢字的讀法呢？"},{"id":"46ab9a0de786","level":"N4","category":"敬語","pattern":"〜れる／られる（尊敬）","before":"","frags":["社長（しゃちょう）はもう","帰（かえ）ら","れ","ました"],"after":"。","connection":"動詞ない形（去ない）＋ れる／られる","note":"尊敬語，與被動同形，語氣較「お〜になる」輕","ex_zh":"社長已經回去了。"},{"id":"775ffee11fbf","level":"N4","category":"敬語","pattern":"お〜になる","before":"","frags":["先生（せんせい）はもう","お帰（かえ）りに","なり","ました"],"after":"。","connection":"お ＋ 動詞ます形 ＋ になる","note":"和語動詞的尊敬語基本型，比「〜れる」更禮貌","ex_zh":"老師已經回去了。"},{"id":"f0c1f16a5701","level":"N4","category":"敬語","pattern":"ご覧になる","before":"","frags":["この","写真（しゃしん）を","ご覧（らん）に","なりましたか。"],"after":"","connection":"「見る」的尊敬語動詞","note":"「見る」的尊敬語；謙讓語為「拝見する」","ex_zh":"您看過這張照片了嗎？"},{"id":"ce5ec62cc3cb","level":"N4","category":"敬語","pattern":"お〜する／ご〜する（謙譲語）","before":"私（わたし）が","frags":["駅（えき）まで","お送（おく）り","し","ます。"],"after":"","connection":"お ＋ 動詞ます形 ＋ する／ご ＋ 漢語名詞 ＋ する","note":"謙讓語基本型，漢語動詞用「ご〜する」","ex_zh":"由我送您到車站。"},{"id":"36389df36384","level":"N4","category":"敬語","pattern":"申す","before":"私（わたし）は","frags":["林（りん）と","申（もう）","し","ます。"],"after":"","connection":"「言う」的謙讓語動詞","note":"「言う」的謙讓語；更禮貌用「申し上げる」","ex_zh":"我姓林。"},{"id":"d9dd5fce0931","level":"N4","category":"接続・その他","pattern":"〜し（並列・理由）","before":"","frags":["この","店（みせ）は","安（やす）いし、","おいしい。"],"after":"","connection":"普通形 ＋ し","note":"可列舉多項理由，暗示還有其他原因","ex_zh":"這家店又便宜又好吃。"},{"id":"e52e1558c879","level":"N4","category":"接続・その他","pattern":"〜のに","before":"薬（くすり）を","frags":["飲（の）んだ","のに、","熱（ねつ）が","下（さ）がらない。"],"after":"","connection":"名詞な／な形容詞な／い形容詞・動詞普通形 ＋ のに","note":"帶有意外、不滿的語氣，比「〜が」更主觀","ex_zh":"明明吃了藥，燒卻沒退。"},{"id":"c26f90c478be","level":"N4","category":"接続・その他","pattern":"〜ので","before":"","frags":["頭（あたま）が","痛（いた）いので、","早（はや）く","帰（かえ）ります。"],"after":"","connection":"名詞な／な形容詞な／い形容詞・動詞普通形 ＋ ので","note":"語氣較「から」客氣委婉，多用於客觀因果","ex_zh":"因為頭痛，我要早點回去。"},{"id":"51a84f8994d1","level":"N4","category":"接続・その他","pattern":"〜ため（に）","before":"","frags":["事故（じこ）","のため、","電車（でんしゃ）が遅（おく）れて","いる"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞普通形 ＋ ため（に）","note":"書面語，可表原因或目的，視前後文判斷","ex_zh":"因為事故，電車誤點了。"},{"id":"7fe0386d1a9b","level":"N4","category":"接続・その他","pattern":"〜場合","before":"","frags":["地震（じしん）の場合（ばあい）は、","エレベーターを","使（つか）わないで","ください"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞普通形 ＋ 場合","note":"多用於說明規則、假設的狀況","ex_zh":"地震時請勿使用電梯。"},{"id":"a1392db9a454","level":"N4","category":"接続・その他","pattern":"〜間に","before":"","frags":["母（はは）が","寝（ね）ている間（あいだ）に、","宿題（しゅくだい）を","した"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞辞書形・ている形 ＋ 間に","note":"強調在某段時間內完成某動作（瞬間性）","ex_zh":"趁媽媽睡覺的期間，我做了功課。"},{"id":"051a28701bd8","level":"N4","category":"接続・その他","pattern":"〜間","before":"","frags":["夏休（なつやす）み","の間（あいだ）、","ずっと祖母（そぼ）の家（いえ）に","いた"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞辞書形・ている形 ＋ 間","note":"強調持續的動作或狀態，後項也是持續的","ex_zh":"整個暑假期間我都待在祖母家。"},{"id":"6b97ec5ce9a4","level":"N4","category":"接続・その他","pattern":"〜うちに","before":"","frags":["熱（あつ）い","うちに、","召（め）し上（あ）がって","ください"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞辞書形・ている形・ない形 ＋ うちに","note":"「〜ないうちに」表示趁還沒…之前","ex_zh":"請趁熱享用。"},{"id":"8559b544527e","level":"N4","category":"接続・その他","pattern":"〜ずに","before":"","frags":["朝（あさ）ご飯（はん）を","食（た）べずに","学校（がっこう）へ","行（い）った"],"after":"。","connection":"動詞ない形（去ない）＋ ずに","note":"書面語，等同「〜ないで」；「する」→「せずに」","ex_zh":"沒吃早餐就去學校了。"},{"id":"40272a613af3","level":"N4","category":"接続・その他","pattern":"〜ないで","before":"","frags":["電気（でんき）を","消（け）さないで","寝（ね）て","しまった"],"after":"。","connection":"動詞ない形 ＋ で","note":"口語，也可用於請求「〜ないでください」","ex_zh":"沒關燈就睡著了。"},{"id":"6b1819193ea9","level":"N4","category":"接続・その他","pattern":"〜まま","before":"","frags":["窓（まど）を","開（あ）けたまま","出（で）かけて","しまった"],"after":"。","connection":"名詞の／な形容詞な／い形容詞・動詞た形・ない形 ＋ まま","note":"表狀態未變、維持原樣進行下一動作","ex_zh":"就那樣開著窗出門了。"},{"id":"4bcd21feaa05","level":"N4","category":"接続・その他","pattern":"〜という（名詞修飾）","before":"","frags":["「君（きみ）の名（な）は。」","という","アニメを","見（み）ました"],"after":"。","connection":"名詞 ＋ という ＋ 名詞","note":"用於介紹對方不知道的人名、地名、事物名","ex_zh":"我看了一部叫《你的名字》的動畫。"},{"id":"005aa90f3fbe","level":"N4","category":"接続・その他","pattern":"〜かどうか","before":"","frags":["彼（かれ）が","来（く）る","かどうか","分（わ）からない"],"after":"。","connection":"名詞／な形容詞語幹／い形容詞・動詞普通形 ＋ かどうか","note":"疑問句中沒有疑問詞時用「かどうか」","ex_zh":"不知道他是否會來。"},{"id":"00e799a98e4a","level":"N4","category":"接続・その他","pattern":"〜か〜か","before":"","frags":["コーヒーか紅茶（こうちゃ）か、","どちらが","いい","ですか"],"after":"。","connection":"名詞／普通形 ＋ か ＋ 名詞／普通形 ＋ か","note":"列舉兩個以上選項，句中含疑問詞時用「〜か」","ex_zh":"咖啡還是紅茶，您想要哪個？"},{"id":"bced21a1be9e","level":"N4","category":"接続・その他","pattern":"〜たらいい","before":"","frags":["分（わ）からない時（とき）は、","先生（せんせい）に","聞（き）いたら","いいですよ"],"after":"。","connection":"動詞た形 ＋ らいい","note":"用於給建議，比「〜ばいい」口語","ex_zh":"不懂的時候，問老師就好囉。"},{"id":"31bd3719dc48","level":"N4","category":"接続・その他","pattern":"〜といい","before":"","frags":["明日（あした）、","晴（は）れる","といい","ですね"],"after":"。","connection":"動詞辞書形 ＋ といい","note":"表達期望、祝願，多用於好事","ex_zh":"明天要是放晴就好了呢。"}]